# ============================================
# API Server Environment Configuration
# Copy to .env and fill in actual values
# ============================================

# Server
PORT=3100
APP_NAME=internal-platform-api
NODE_ENV=development  # development | test | production

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=internal_platform
DB_USER=root
DB_PASSWORD=root

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=7200

# Lingxing ERP API
LINGXING_APP_ID=
LINGXING_APP_SECRET=
LINGXING_BASE_URL=https://openapi.lingxing.com

# Lemon Cloud API
LEMONCLOUD_BASE_URL=https://open2.ningmengyun.com
LEMONCLOUD_APP_KEY=
LEMONCLOUD_APP_SECRET=

# MinIO / Object Storage
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=internal-platform

# External API mock mode (set to 'true' to use mock data instead of live APIs)
MOCK_EXTERNAL_API=false
