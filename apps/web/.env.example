# ============================================
# Web Frontend Environment Configuration
# Copy to .env and fill in actual values
# ============================================

# Dev server port
PORT=3200

# API base URL (used by the frontend to make API calls)
# Development: local API server
VITE_API_BASE_URL=http://localhost:3100

# Production: relative path (proxied by Nginx)
# VITE_API_BASE_URL=

# App title
VITE_APP_TITLE=Linxi Internal Platform
